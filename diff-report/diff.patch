-   always @( * ) begin
-      case ( ALUOp )
-      `ALUOp_lui:C=B;
-      `ALUOp_add:C=A+B;
-      `ALUOp_sub:C=A-B;  //and beq
-      `ALUOp_xor:C=A^B;
-      `ALUOp_or:C=A|B;
-      `ALUOp_and:C=A&B;
-      `ALUOp_sll:C=A<<B;
-      `ALUOp_srl:C=A>>B;
-      `ALUOp_sra:C=A>>>B;
